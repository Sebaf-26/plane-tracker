# Coordinate del receiver ADS-B (PRIVATE — non committare il tuo .env reale)
READSB_LAT=41.0000
READSB_LON=12.0000
READSB_ALT=50m

# Timezone
TZ=Europe/Rome

# Porta host per l'interfaccia web tar1090 (originale)
WEB_PORT=8080

# Porta host per il radar React moderno
UI_PORT=8090

# Guadagno SDR (autogain o valore numerico es. 49.6)
READSB_GAIN=autogain
