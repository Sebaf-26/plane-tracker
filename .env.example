# Coordinate del receiver ADS-B (PRIVATE — non committare il tuo .env reale)
READSB_LAT=41.0000
READSB_LON=12.0000
READSB_ALT=50m

# Timezone
TZ=Europe/Rome

# Porta host per il radar React
UI_PORT=8090

# Path sull'host dove salvare il database SQLite (persiste tra i redeploy)
DB_HOST_PATH=/opt/hydraplanes/data

# Minuti di storico da conservare (default 10)
RETAIN_MINUTES=10

# Guadagno SDR (autogain o valore numerico es. 49.6)
READSB_GAIN=autogain
